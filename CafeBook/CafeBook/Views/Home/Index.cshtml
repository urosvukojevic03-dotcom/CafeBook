@{
    ViewData["Title"] = "Početna";
}

<div class="container mt-5">
    <!-- Hero sekcija -->
    <div class="text-center py-5">
        <div style="font-size: 5rem;">☕</div>
        <h1 style="color: var(--cafe-dark); font-size: 3rem; font-weight: bold;">
            Dobrodošli u CafeBook
        </h1>
        <p class="mt-3" style="font-size: 1.2rem; color: #6f4e37;">
            Rezervišite vaš sto brzo i jednostavno — bez čekanja!
        </p>
        <a asp-controller="Rezervacija" asp-action="Index" class="btn btn-success btn-lg mt-3">
            <i class="fas fa-calendar-alt"></i> Rezervišite sto
        </a>
    </div>

    <hr style="border-color: var(--cafe-light);" />

    <!-- Kartice sa informacijama -->
    <div class="row mt-4 text-center">
        <div class="col-md-4 mb-4">
            <div class="card h-100 p-3">
                <div class="card-body">
                    <div style="font-size: 2.5rem;">🪑</div>
                    <h5 class="mt-3" style="color: var(--cafe-dark);">Odaberite sto</h5>
                    <p class="text-muted">Birајte između stolova unutra, na terasi ili pored bara.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 p-3">
                <div class="card-body">
                    <div style="font-size: 2.5rem;">📅</div>
                    <h5 class="mt-3" style="color: var(--cafe-dark);">Izaberite vreme</h5>
                    <p class="text-muted">Rezervišite tačno kada vam odgovara — dan i sat po vašem izboru.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 p-3">
                <div class="card-body">
                    <div style="font-size: 2.5rem;">✅</div>
                    <h5 class="mt-3" style="color: var(--cafe-dark);">Potvrdite rezervaciju</h5>
                    <p class="text-muted">Brza i jednostavna potvrda — bez poziva, bez čekanja.</p>
                </div>
            </div>
        </div>
    </div>
</div>
