@model List<CafeBook.DAL.Models.Rezervacija>

@{
    ViewData["Title"] = "Admin panel";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fas fa-list"></i> Sve rezervacije</h2>
        <a asp-action="Odjava" class="btn btn-outline-danger">
            <i class="fas fa-sign-out-alt"></i> Odjavi se
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Trenutno nema rezervacija.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th><i class="fas fa-user"></i> Ime gosta</th>
                            <th><i class="fas fa-phone"></i> Telefon</th>
                            <th><i class="fas fa-clock"></i> Datum i vreme</th>
                            <th><i class="fas fa-users"></i> Br. osoba</th>
                            <th><i class="fas fa-chair"></i> Sto</th>
                            <th>Akcija</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>@r.ImeGosta</td>
                                <td>@r.BrojTelefona</td>
                                <td>@r.DatumVreme.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@r.BrojOsoba</td>
                                <td>Sto @r.Stol?.BrojStola (@r.Stol?.Lokacija)</td>
                                <td>
                                    <a asp-action="Obrisi" asp-route-id="@r.Id"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Da li ste sigurni da želite da obrišete ovu rezervaciju?')">
                                        <i class="fas fa-trash"></i> Obriši
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
