<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CafeBook</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --cafe-dark: #2c1a0e;
            --cafe-brown: #6f4e37;
            --cafe-light: #d4a96a;
            --cafe-cream: #f5f0e8;
        }

        body {
            background-color: var(--cafe-cream);
            font-family: 'Georgia', serif;
        }

        .navbar {
            background-color: var(--cafe-dark) !important;
            border-bottom: 3px solid var(--cafe-light);
        }

        .navbar-brand {
            font-size: 1.6rem;
            color: var(--cafe-light) !important;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .nav-link {
            color: #ccc !important;
            font-size: 1rem;
            margin-left: 10px;
            transition: color 0.3s;
        }

            .nav-link:hover {
                color: var(--cafe-light) !important;
            }

        footer {
            background-color: var(--cafe-dark);
            color: var(--cafe-light);
            padding: 20px 0;
            margin-top: 60px;
            text-align: center;
            font-size: 0.9rem;
            border-top: 3px solid var(--cafe-light);
        }

        .btn-success {
            background-color: var(--cafe-brown) !important;
            border-color: var(--cafe-brown) !important;
        }

            .btn-success:hover {
                background-color: var(--cafe-dark) !important;
            }

        .table-dark {
            background-color: var(--cafe-dark) !important;
        }

        h2 {
            color: var(--cafe-dark);
            font-weight: bold;
        }

        .form-control:focus {
            border-color: var(--cafe-light);
            box-shadow: 0 0 0 0.2rem rgba(111, 78, 55, 0.25);
        }

        .card {
            border: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border-radius: 12px;
        }

        .card-header {
            background-color: var(--cafe-brown);
            color: white;
            border-radius: 12px 12px 0 0 !important;
            font-size: 1.2rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/">☕ CafeBook</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home"></i> Početna
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Rezervacija" asp-action="Stolovi">
                            <i class="fas fa-chair"></i> Stolovi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Rezervacija" asp-action="Index">
                            <i class="fas fa-calendar-alt"></i> Rezervacija
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Prijava">
                            <i class="fas fa-lock"></i> Admin
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="py-4">
        @RenderBody()
    </main>

    <footer>
        <p class="mb-0">☕ © 2024 CafeBook — Sistem za rezervaciju stolova</p>
        <small>Sva prava zadržana</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>