@model List<CafeBook.DAL.Models.Stol>

@{
    ViewData["Title"] = "Pregled stolova";
    var zauzetiStolovi = ViewBag.ZauzetiStolovi as List<int> ?? new List<int>();
}

<div class="container mt-5">
    <h2 class="text-center mb-4">
        <i class="fas fa-chair"></i> Pregled stolova
    </h2>

    <!-- Legenda -->
    <div class="d-flex justify-content-center gap-4 mb-4">
        <span>
            <span class="badge" style="background-color:#28a745;">●</span>
            Slobodan
        </span>
        <span>
            <span class="badge" style="background-color:#dc3545;">●</span>
            Zauzet
        </span>
    </div>

    <div class="row">
        @foreach (var stol in Model)
        {
            bool zauzet = zauzetiStolovi.Contains(stol.Id);
            string boja = zauzet ? "#dc3545" : "#28a745";
            string status = zauzet ? "Zauzet" : "Slobodan";
            string ikona = zauzet ? "fas fa-times-circle" : "fas fa-check-circle";

            <div class="col-md-4 mb-4">
                <div class="card text-center h-100"
                     style="border-top: 5px solid @boja;">
                    <div class="card-body p-4">
                        <div style="font-size: 3rem;">🪑</div>
                        <h4 class="mt-2" style="color: var(--cafe-dark);">
                            Sto @stol.BrojStola
                        </h4>
                        <p class="text-muted mb-1">
                            <i class="fas fa-map-marker-alt"></i> @stol.Lokacija
                        </p>
                        <p class="text-muted mb-3">
                            <i class="fas fa-users"></i> Do @stol.Kapacitet osoba
                        </p>
                        <span class="badge fs-6 px-3 py-2"
                              style="background-color: @boja;">
                            <i class="@ikona"></i> @status
                        </span>
                    </div>
                    @if (!zauzet)
                    {
                        <div class="card-footer bg-transparent">
                            <a asp-action="Index" class="btn btn-success btn-sm w-100">
                                <i class="fas fa-calendar-plus"></i> Rezerviši
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>